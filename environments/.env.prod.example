# PROD environment — copy to `environments/.env.prod` (gitignored) and fill in.
# Selected at runtime:  test_env=prod uv run pytest ...
# CAUTION: prod points tests at the live system — use read-only / safe flows only.
# See .env.example for the full key list (API / gRPC / mobile / AI).

AUTH_URL=https://auth.example.com/signin
APP_URL=https://app.example.com
# APP_USER=
# APP_PASS=
# API_BASE_URL=https://api.example.com
# GRPC_HOST=grpc.example.com
# GRPC_PORT=443
# GRPC_TLS=true
