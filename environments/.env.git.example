# Git-provider config for the ship step (create_mr.py). Copy to
# environments/.env.git (gitignored) and fill ONLY your provider's block —
# provider + repo are auto-detected from the `origin` remote; set GIT_PROVIDER
# to override detection.
#GIT_PROVIDER=gitlab|github|bitbucket|azure|gitea
#GIT_TOKEN=generic-fallback-token

# GitLab (self-hosted: also set GITLAB_URL)
#GITLAB_TOKEN=glpat-...
#GITLAB_URL=https://gitlab.example.com

# GitHub (github.com or Enterprise — Enterprise API URL is derived from the host)
#GITHUB_TOKEN=ghp_...

# Bitbucket Cloud (app password preferred)
#BITBUCKET_USER=your-username
#BITBUCKET_APP_PASSWORD=...

# Azure DevOps Repos
#AZURE_DEVOPS_PAT=...

# Gitea / Forgejo / Codeberg
#GITEA_TOKEN=...
