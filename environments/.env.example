# Master reference of ALL keys. Per-env templates live alongside this file:
#   .env.dev.example · .env.test.example · .env.prod.example
# Copy the one you need to environments/.env.<env> (e.g. .env.test) and fill it
# in. `test_env=<env>` selects the file at runtime, e.g.:
#   test_env=prod uv run pytest ...   → loads environments/.env.prod
# Valid envs: dev | test | prod (default: test).

# ---- Web UI ----------------------------------------------------------------
AUTH_URL=https://auth.example.com/signin
APP_URL=https://app.example.com
# APP_USER=
# APP_PASS=

# ---- API (tests/api) -------------------------------------------------------
# API_BASE_URL=https://api.example.com   # falls back to APP_URL
# API_TOKEN=

# ---- gRPC (tests/grpc) -----------------------------------------------------
# Defaults target the in-process mock, so tests run with no backend.
# GRPC_HOST=localhost
# GRPC_PORT=50051
# GRPC_TLS=false
# GRPC_TOKEN=

# ---- Mobile (tests/mobile) -------------------------------------------------
# Native (Appium) is skip-gated unless ALLOW_MOBILE_NATIVE=1.
# APPIUM_URL=http://127.0.0.1:4723
# MOBILE_PLATFORM=android        # android | ios
# DEVICE_GRID=local              # local | browserstack | saucelabs
# MOBILE_APP=                    # path / URL / cloud app id of the build
# BROWSERSTACK_USERNAME=
# BROWSERSTACK_ACCESS_KEY=
# SAUCE_USERNAME=
# SAUCE_ACCESS_KEY=

# ---- AI QA Agent -----------------------------------------------------------
# AI_PROVIDER=claude             # claude | openai | noop
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
