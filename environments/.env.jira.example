# Jira credentials for the failure → Bug auto-reporter
# (src/aiqa_framework/jira/bug_reporter.py, used from the conftest hook).
#
# 1. Copy this file to `.env.jira` in the same folder.
# 2. Generate an Atlassian API token:
#       https://id.atlassian.com/manage-profile/security/api-tokens
# 3. Fill the values below. The real .env.jira is gitignored — never commit it.

JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_TOKEN=
JIRA_PROJECT=PROJ
