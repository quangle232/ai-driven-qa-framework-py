# TEST environment (default) — copy to `environments/.env.test` (gitignored) and fill in.
# Selected at runtime:  test_env=test uv run pytest ...   (or just the defaults)
# See .env.example for the full key list (API / gRPC / mobile / AI).

AUTH_URL=https://auth.test.example.com/signin
APP_URL=https://app.test.example.com
# APP_USER=
# APP_PASS=
# API_BASE_URL=https://api.test.example.com
# GRPC_HOST=test-grpc.example.com
# GRPC_PORT=50051
